{
    "configurations": [
        {
            "name": "STM32",
            "compilerPath": "${env:USERPROFILE}/AppData/Local/stm32cube/bundles/gnu-tools-for-stm32/14.3.1+st.2/bin/arm-none-eabi-g++.exe",
            "compileCommands": [
                "${workspaceFolder}/build/Debug/compile_commands.json"
            ],
            "includePath": [
                "${workspaceFolder}/User",
                "${workspaceFolder}/Core/Inc",
                "${workspaceFolder}/Drivers/CMSIS/DSP/Include",
                "${workspaceFolder}/Drivers/CMSIS/Device/ST/STM32H7xx/Include",
                "${workspaceFolder}/Drivers/CMSIS/Include",
                "${workspaceFolder}/Drivers/STM32H7xx_HAL_Driver/Inc",
                "${workspaceFolder}/Drivers/STM32H7xx_HAL_Driver/Inc/Legacy",
                "${workspaceFolder}/Middlewares/Third_Party/FreeRTOS/Source/include",
                "${workspaceFolder}/Middlewares/Third_Party/FreeRTOS/Source/CMSIS_RTOS_V2",
                "${workspaceFolder}/Middlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4F",
                "${workspaceFolder}/User/device"
            ],
            "defines": [
                "ARM_MATH_CM7",
                "DEBUG",
                "STM32H723xx",
                "USE_HAL_DRIVER",
                "USE_PWR_LDO_SUPPLY"
            ],
            "intelliSenseMode": "gcc-arm",
            "cStandard": "c17",
            "cppStandard": "gnu++17"
        }
    ],
    "version": 4
}