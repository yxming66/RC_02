float AbsFloat(float value) {
  return mr::component::math::abs_scalar(value);
}

float ClampFloat(float value, float lower, float upper) {
  if (!mr::component::math::is_finite_scalar(value)) {
    return lower;
  }
  return mr::component::math::clamp_scalar(value, lower, upper);
}

float PositiveOr(float value, float fallback) {
  return (mr::component::math::is_finite_scalar(value) && value > 0.0f) ? value : fallback;
}

bool NearlyEqual(float lhs, float rhs, float eps = 1.0e-6f) {
  return AbsFloat(lhs - rhs) <= eps;
}

