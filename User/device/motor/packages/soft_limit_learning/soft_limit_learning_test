mr::motor::SoftLimitReturnTarget DecodeReturnTarget(uint8_t target) {
  switch (target) {
    case 1u:
      return mr::motor::SoftLimitReturnTarget::Lower;
    case 2u:
      return mr::motor::SoftLimitReturnTarget::Center;
    case 3u:
      return mr::motor::SoftLimitReturnTarget::Upper;
    case 0u:
    default:
      return mr::motor::SoftLimitReturnTarget::None;
  }
}

bool PidParamsChanged(const MotorLimitTestPidParams& lhs,
                      const volatile MotorLimitTestPidParams& rhs) {
  return !NearlyEqual(lhs.k, rhs.k) ||
         !NearlyEqual(lhs.p, rhs.p) ||
         !NearlyEqual(lhs.i, rhs.i) ||
         !NearlyEqual(lhs.d, rhs.d) ||
         !NearlyEqual(lhs.i_limit, rhs.i_limit) ||
         !NearlyEqual(lhs.out_limit, rhs.out_limit) ||
         !NearlyEqual(lhs.d_cutoff_hz, rhs.d_cutoff_hz) ||
         !NearlyEqual(lhs.range, rhs.range);
}

bool PidConfigChanged() {
  return !g_last_pid_params_valid ||
         PidParamsChanged(g_last_vel_pid_params, g_motor_limit_test_vel_pid) ||
         PidParamsChanged(g_last_pos_pid_params, g_motor_limit_test_pos_pid);
}

