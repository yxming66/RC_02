void BuildControllerConfig() {
  CopyPidParamsFromDebug();
  g_controller_config.velocity_pid = &g_velocity_pid;
  g_controller_config.position_pid = &g_position_pid;
  g_controller_config.sample_freq = kTaskFreqHz;
  g_controller_config.position_to_velocity_limit =
      PositiveOr(g_motor_limit_test_controller.position_to_velocity_limit, 0.6f);
  g_controller_config.velocity_to_torque_limit =
      ClampFloat(PositiveOr(g_motor_limit_test_controller.velocity_to_torque_limit, 1.0f), 0.01f, kMaxM2006TorqueNm);
  g_controller_config.feedback_lowpass_cutoff_hz = PositiveOr(g_motor_limit_test_controller.feedback_lowpass_cutoff_hz, 0.0f);
  g_controller_config.output_lowpass_cutoff_hz = PositiveOr(g_motor_limit_test_controller.output_lowpass_cutoff_hz, 0.0f);
}

bool ControllerConfigChanged() {
  return PidConfigChanged() ||
         !NearlyEqual(g_last_controller_position_to_velocity_limit, g_motor_limit_test_controller.position_to_velocity_limit) ||
         !NearlyEqual(g_last_controller_velocity_to_torque_limit, g_motor_limit_test_controller.velocity_to_torque_limit) ||
         !NearlyEqual(g_last_controller_feedback_cutoff_hz, g_motor_limit_test_controller.feedback_lowpass_cutoff_hz) ||
         !NearlyEqual(g_last_controller_output_cutoff_hz, g_motor_limit_test_controller.output_lowpass_cutoff_hz);
}

void RememberControllerConfig() {
  g_last_controller_position_to_velocity_limit = g_motor_limit_test_controller.position_to_velocity_limit;
  g_last_controller_velocity_to_torque_limit = g_motor_limit_test_controller.velocity_to_torque_limit;
  g_last_controller_feedback_cutoff_hz = g_motor_limit_test_controller.feedback_lowpass_cutoff_hz;
  g_last_controller_output_cutoff_hz = g_motor_limit_test_controller.output_lowpass_cutoff_hz;
  RememberPidConfig();
}

void RebuildController() {
  if (g_motor == nullptr) {
    return;
  }
  BuildControllerConfig();
  g_controller = new (g_controller_storage) ControllerType(*g_motor, g_controller_config);
  RememberControllerConfig();
}

void UpdateLearningConfigFromDebug() {
  g_learning_config.seek_velocity_rad_s =
      mr::component::math::positive_or_zero(g_motor_limit_test_learning.seek_velocity_rad_s);
  g_learning_config.known_travel_rad =
      mr::component::math::positive_or_zero(g_motor_limit_test_learning.travel_rad);
  g_learning_config.limit_margin_rad =
      mr::component::math::positive_or_zero(g_motor_limit_test_learning.limit_margin_rad);
  g_learning_config.min_range_rad =
      mr::component::math::positive_or_zero(g_motor_limit_test_learning.min_range_rad);
  g_limit_learner.Configure(g_learning_config);
  g_limit_learner.SetPostLearnReturnTarget(
      DecodeReturnTarget(g_motor_limit_test_learning.post_learn_return_target));
}

void ApplyPostLearnReturnTargetIfReady() {
  if (g_controller == nullptr) {
    return;
  }

  const bool is_seeking = g_limit_learner.IsSeeking();
  const bool just_finished_learning = g_was_learning_seeking && !is_seeking && g_limit_learner.IsReady();
  g_was_learning_seeking = is_seeking;

  if (!just_finished_learning || !g_limit_learner.HasPostLearnTargetPosition()) {
    return;
  }

  const float target = g_limit_learner.GetPostLearnTargetPosition();
  const float max_velocity = PositiveOr(g_motor_limit_test_learning.post_learn_return_max_velocity_rad_s,
                                        g_controller_config.position_to_velocity_limit);
  g_motor_limit_test_position.target_rad = target;
  g_motor_limit_test_controller_obs.command_position = target;
  g_motor_limit_test_controller_obs.command_velocity = max_velocity;
  g_motor_limit_test_status_obs.set_cmd_ret = g_controller->SetPosition(target, max_velocity);
  g_returning_to_post_learn_target = true;
}

bool PostLearnReturnCommandActive() {
  return g_returning_to_post_learn_target &&
         g_limit_learner.IsReady() &&
         g_limit_learner.HasPostLearnTargetPosition();
}

void UpdateObservations() {
  if (g_controller == nullptr) {
    return;
  }

  const mr::motor::MotorState state = g_controller->GetState();
  const mr::motor::SoftLimitRange& range = g_limit_learner.GetRange();

  g_motor_limit_test_status_obs.initialized = (g_motor != nullptr && g_controller != nullptr) ? 1u : 0u;
  g_motor_limit_test_status_obs.online = state.online ? 1u : 0u;
  g_motor_limit_test_status_obs.protocol_state = static_cast<uint8_t>(state.protocol_state);
  g_motor_limit_test_status_obs.last_commit_ok = state.last_commit_ok ? 1u : 0u;
  g_motor_limit_test_status_obs.fault = state.protocol_fault;
  g_motor_limit_test_motor_obs.position_rad = state.position_rad;
  g_motor_limit_test_motor_obs.single_turn_rad = state.position_single_turn_rad;
  g_motor_limit_test_motor_obs.velocity_rad_s = state.velocity_rad_s;
  g_motor_limit_test_motor_obs.torque_nm = state.torque_nm;
  g_motor_limit_test_motor_obs.temperature_c = state.temperature_c;
  g_motor_limit_test_controller_obs.output_nm = g_controller->GetLastOutputTorque();
  g_motor_limit_test_controller_obs.feedback_pos = g_controller->GetLastFeedbackPosition();
  g_motor_limit_test_controller_obs.feedback_vel = g_controller->GetLastFeedbackVelocity();
  g_motor_limit_test_learning_obs.state = static_cast<uint8_t>(g_limit_learner.GetState());
  g_motor_limit_test_learning_obs.workflow = static_cast<uint8_t>(g_limit_learner.GetWorkflow());
  g_motor_limit_test_learning_obs.seek_startup_ignore_left_s = g_limit_learner.GetStartupIgnoreLeftS();
  g_motor_limit_test_learning_obs.stall_cycles = g_limit_learner.GetStallCycles();
  g_motor_limit_test_learning_obs.elapsed_seek_s = g_limit_learner.GetElapsedSeekS();
  g_motor_limit_test_learning_obs.lower_valid = range.lower_valid ? 1u : 0u;
  g_motor_limit_test_learning_obs.upper_valid = range.upper_valid ? 1u : 0u;
  g_motor_limit_test_learning_obs.lower_rad = range.lower_rad;
  g_motor_limit_test_learning_obs.upper_rad = range.upper_rad;
  g_motor_limit_test_learning_obs.travel_rad = g_limit_learner.GetTravelRad();
  g_motor_limit_test_learning_obs.center_rad = g_limit_learner.GetCenterRad();
  g_motor_limit_test_learning_obs.has_post_learn_target = g_limit_learner.HasPostLearnTargetPosition() ? 1u : 0u;
  g_motor_limit_test_learning_obs.returning_to_post_learn_target = g_returning_to_post_learn_target ? 1u : 0u;
  g_motor_limit_test_learning_obs.post_learn_target_rad = g_limit_learner.GetPostLearnTargetPosition();
  g_motor_limit_test_learning_obs.pending_travel_rad = g_limit_learner.GetPendingTravelRad();
}

void HandleDebugCommand() {
  const uint8_t cmd = g_motor_limit_test_command.cmd;
  if (cmd == 0u) {
    return;
  }

  int8_t ret = DEVICE_OK;
  switch (cmd) {
    case 1u:
      ret = g_limit_learner.StartSeekLower() ? DEVICE_OK : DEVICE_ERR;
      if (ret == DEVICE_OK && g_controller) {
        (void)g_controller->ResetControllers();
        g_returning_to_post_learn_target = false;
      }
      break;
    case 2u:
      ret = g_limit_learner.StartSeekUpper() ? DEVICE_OK : DEVICE_ERR;
      if (ret == DEVICE_OK && g_controller) {
        (void)g_controller->ResetControllers();
        g_returning_to_post_learn_target = false;
      }
      break;
    case 3u:
      ret = g_limit_learner.CaptureLowerFromObserved() ? DEVICE_OK : DEVICE_ERR;
      break;
    case 4u:
      ret = g_limit_learner.CaptureUpperFromObserved() ? DEVICE_OK : DEVICE_ERR;
      break;
    case 5u:
      g_limit_learner.CancelSeek();
      g_was_learning_seeking = false;
      g_returning_to_post_learn_target = false;
      ret = DEVICE_OK;
      break;
    case 6u:
      g_limit_learner.ClearRange();
      g_was_learning_seeking = false;
      g_returning_to_post_learn_target = false;
      ret = DEVICE_OK;
      break;
    case 7u:
      ret = g_limit_learner.SetRange(g_motor_limit_test_learning.manual_lower_rad,
                                     g_motor_limit_test_learning.manual_upper_rad)
                ? DEVICE_OK
                : DEVICE_ERR;
      break;
    case 8u:
      if (g_controller) {
        (void)g_controller->ResetControllers();
      }
      RebuildController();
      ret = DEVICE_OK;
      break;
    case 9u:
      ret = g_limit_learner.StartSeekLowerWithTravel()
                ? DEVICE_OK
                : DEVICE_ERR;
      if (ret == DEVICE_OK && g_controller) {
        (void)g_controller->ResetControllers();
        g_returning_to_post_learn_target = false;
      }
      break;
    case 10u:
      ret = g_limit_learner.StartSeekUpperWithTravel()
                ? DEVICE_OK
                : DEVICE_ERR;
      if (ret == DEVICE_OK && g_controller) {
        (void)g_controller->ResetControllers();
        g_returning_to_post_learn_target = false;
      }
      break;
    case 11u:
      ret = g_limit_learner.StartSeekUpperThenLower()
                ? DEVICE_OK
                : DEVICE_ERR;
      if (ret == DEVICE_OK && g_controller) {
        (void)g_controller->ResetControllers();
        g_returning_to_post_learn_target = false;
      }
      break;
    case 12u:
      ret = g_limit_learner.StartSeekLowerThenUpper()
                ? DEVICE_OK
                : DEVICE_ERR;
      if (ret == DEVICE_OK && g_controller) {
        (void)g_controller->ResetControllers();
        g_returning_to_post_learn_target = false;
      }
      break;
    default:
      ret = DEVICE_ERR_UNSUPPORTED;
      break;
  }

  g_motor_limit_test_status_obs.command_ret = ret;
  g_motor_limit_test_command.cmd = 0u;
}

void ApplySelectedControl() {
  if (g_controller == nullptr) {
    g_motor_limit_test_status_obs.set_cmd_ret = DEVICE_ERR_NULL;
    return;
  }

  const mr::motor::MotorState state = g_controller->GetState();

  if (g_limit_learner.IsSeeking()) {
    const float velocity = g_limit_learner.GetSeekVelocity();
    g_motor_limit_test_controller_obs.command_velocity = velocity;
    g_motor_limit_test_controller_obs.command_position = state.position_rad;
    g_motor_limit_test_status_obs.set_cmd_ret = g_controller->SetVelocity(velocity);
    return;
  }

  if (PostLearnReturnCommandActive()) {
    const float position = g_limit_learner.GetPostLearnTargetPosition();
    const float max_velocity = PositiveOr(g_motor_limit_test_learning.post_learn_return_max_velocity_rad_s,
                                          g_controller_config.position_to_velocity_limit);
    g_motor_limit_test_position.target_rad = position;
    g_motor_limit_test_controller_obs.command_velocity = max_velocity;
    g_motor_limit_test_controller_obs.command_position = position;
    g_motor_limit_test_status_obs.set_cmd_ret = g_controller->SetPosition(position, max_velocity);
    return;
  }

  switch (g_motor_limit_test_safety.protocol) {
    case 0u: {
      float velocity = g_motor_limit_test_velocity.target_rad_s;
      velocity = g_limit_learner.LimitVelocity(state.position_rad, velocity);
      g_motor_limit_test_controller_obs.command_velocity = velocity;
      g_motor_limit_test_controller_obs.command_position = state.position_rad;
      g_motor_limit_test_status_obs.set_cmd_ret = g_controller->SetVelocity(velocity);
      break;
    }
    case 1u: {
      const float position = g_limit_learner.ClampPosition(g_motor_limit_test_position.target_rad);
      const float max_velocity = PositiveOr(g_motor_limit_test_position.max_velocity_rad_s,
                                            g_controller_config.position_to_velocity_limit);
      g_motor_limit_test_controller_obs.command_velocity = max_velocity;
      g_motor_limit_test_controller_obs.command_position = position;
      g_motor_limit_test_status_obs.set_cmd_ret = g_controller->SetPosition(position, max_velocity);
      break;
    }
    case 2u: {
      const float position = g_limit_learner.ClampPosition(g_motor_limit_test_mit.target_position_rad);
      float velocity = g_motor_limit_test_mit.target_velocity_rad_s;
      velocity = g_limit_learner.LimitVelocity(state.position_rad, velocity);
      const float torque_ff = ClampFloat(g_motor_limit_test_mit.torque_ff_nm,
                                         -kMaxM2006TorqueNm,
                                         kMaxM2006TorqueNm);
      g_motor_limit_test_controller_obs.command_velocity = velocity;
      g_motor_limit_test_controller_obs.command_position = position;
      g_motor_limit_test_status_obs.set_cmd_ret = g_controller->SetMIT(position,
                               velocity,
                               g_motor_limit_test_mit.kp,
                               g_motor_limit_test_mit.kd,
                               torque_ff);
      break;
    }
    default:
      g_motor_limit_test_status_obs.set_cmd_ret = g_controller->SetVelocity(0.0f);
      break;
  }
}

void InitializeTestMotor() {
  g_motor_limit_test_status_obs.can_init_ret = BSP_CAN_Init();

  const mr::motor::MotorInstallSpec direct_install{1.0f, false};
  g_motor = mr::motor::MotorFactory::Create<mr::motor::MotorKind::RM, mr::motor::MotorModel::M2006>(
      mr::motor::MotorInstanceConfig<mr::motor::MotorKind::RM>::FromVendorParam(g_rm_param),
      direct_install);

  if (g_motor == nullptr) {
    g_motor_limit_test_status_obs.register_ret = DEVICE_ERR_NULL;
    return;
  }

  g_motor_limit_test_status_obs.register_ret = g_motor->Register();
  RebuildController();
  UpdateLearningConfigFromDebug();

  if (g_controller != nullptr) {
    g_motor_limit_test_status_obs.enable_ret = g_controller->Enable();
  }
}

}  // namespace

